{
  "name": "workouts",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --host",
    "dev:all": "concurrently --kill-others \"pnpm exec convex dev\" \"pnpm dev\"",
    "build": "vite build",
    "build:development": "vite build --mode development",
    "preview": "pnpm build:development && wrangler dev",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "seed:exercises": "pnpm exec convex run seed:seedExercises",
    "seed:test": "pnpm exec convex run seed:seedTestData '{\"userId\":\"user_2tTlbmSTh4kbXmg9v6EN7YW3B4d\"}'",
    "seed:clear": "pnpm exec convex run seed:clearUserData '{\"userId\":\"user_2tTlbmSTh4kbXmg9v6EN7YW3B4d\"}'",
    "seed:reset": "pnpm seed:exercises && pnpm seed:clear && pnpm seed:test",
    "deploy": "pnpm build && wrangler deploy",
    "deploy:dev": "pnpm exec convex dev --once && pnpm build:development && wrangler deploy --env dev",
    "deploy:prod": "pnpm build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@appelent/auth": "^0.1.0",
    "@base-ui/react": "^1.4.1",
    "@clerk/clerk-react": "^5.61.3",
    "@convex-dev/react-query": "0.1.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.10.7",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.26",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@cloudflare/vite-plugin": "^1.35.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "^0.8.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  }
}
