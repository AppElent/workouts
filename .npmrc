# Registry mapping for the private @appelent scope.
# The auth token is NOT stored here: pnpm refuses to expand ${NODE_AUTH_TOKEN}
# from a committed project .npmrc (it could leak to an attacker-controlled
# registry). Put the token line in your user-level ~/.npmrc instead:
#   //npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
# and export NODE_AUTH_TOKEN in your shell. CI sets it on the install step.
@appelent:registry=https://npm.pkg.github.com
